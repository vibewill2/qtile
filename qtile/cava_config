[general]
framerate = 120
bars = 10
autosens = 1
sensitivity = 200
lower_cutoff_freq = 50
higher_cutoff_freq = 10000

[input]
method = pulse
source = auto

[output]
method = raw
raw_target = /tmp/cava.fifo
data_format = ascii
ascii_max_range = 7
bar_delimiter = 0
channels = mono
mono_option = average
